# PacketSage Environment Variables Template
# Copy this file to .env to configure local variables.

# Google Gemini API Key (Secret - Server-side only)
# IMPORTANT: Do not prefix this with VITE_ to prevent browser exposure.
GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
APP_URL=http://localhost:3000
VITE_APP_ENV=development
